{
  "defaults": {
    "text": {
      "provider": "openai",
      "model": "gpt-5.4-nano"
    },
    "speech": {
      "provider": "openai"
    }
  },
  "promptFiles": {
    "stylingSystem": "config/styling-system-prompt.txt"
  },
  "prompts": {
    "styling": {
      "maxWords": 90
    }
  },
  "providers": {
    "openai": {
      "speech": {
        "voice": "onyx",
        "saveAudioByDefault": false
      }
    }
  },
  "tts": {
    "audioDucking": {
      "enabled": true,
      "duckVolume": 0.5
    }
  },
  "trace": {
    "enabled": true
  }
}
